{
  "name": "openstoryflow",
  "productName": "OpenStoryflow",
  "version": "1.0.0",
  "description": "Local-first infinite canvas for creative planning — whiteboard + kanban + mindmap + storyboard with a Gemini-powered AI assistant.",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.josvach.openstoryflow",
    "productName": "OpenStoryflow",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "files": ["main.js", "preload.js", "src/**/*"]
  }
}
